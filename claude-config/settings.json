{
  "agentPushNotifEnabled": true,
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "ai-plugins@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "engram@engram": true,
    "playwright@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "engram": {
      "source": {
        "repo": "Gentleman-Programming/engram",
        "source": "github"
      }
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm -rf ~)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.p12)",
      "Write(*.pfx)"
    ],
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(npm test:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn test:*)",
      "Bash(pytest:*)",
      "Bash(cargo test:*)",
      "Bash(go test:*)",
      "Bash(npm run lint:*)",
      "Bash(pnpm lint:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)",
      "Bash(tsc:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/block-sensitive-files.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/auto-format.js"
          },
          {
            "type": "command",
            "command": "node ~/.claude/scripts/detect-structural-change.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🔒 Reglas activas: NO LEGACY/DEAD CODE · Per-module CLAUDE.md · Verification-first · Strict TDD · Project-detector cascade'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/check-claude-md-freshness.js"
          }
        ]
      }
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true
}
